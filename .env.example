# Local Postgres
# URL-encode reserved characters in the password, e.g. @ -> %40 and # -> %23.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/commitglow"

# BetterAuth configuration
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Github credentials
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Gitlab credentials
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# Bitbucket credentials
BITBUCKET_API_TOKEN=""

# Polar payments
# Use sandbox locally unless you are intentionally testing production products.
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
POLAR_SERVER="sandbox"
POLAR_PRO_PRODUCT_ID=""
POLAR_TEAM_PRODUCT_ID=""

# Nextjs Public
NEXT_PUBLIC_GITHUB_REPO=carbonelldev/commitglow

# Vercel AI Gateway
AI_GATEWAY_API_KEY=""
